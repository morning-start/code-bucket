{
    "version": "2.1.183",
    "description": "Agentic coding assistant by Anthropic — write, edit, debug, and explore your codebase in your terminal",
    "homepage": "https://code.claude.com",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://downloads.claude.ai/claude-code-releases/2.1.183/win32-x64/claude.exe#/claude.exe",
            "hash": "sha256:ba6e71d0e39b33c42a519bd10fc6d79b04d62cedcc918b3991ff863462261eb0"
        },
        "arm64": {
            "url": "https://downloads.claude.ai/claude-code-releases/2.1.183/win32-arm64/claude.exe#/claude.exe",
            "hash": "sha256:0d75484e247f8e30062d143b49f97f317d3347d98d61e1f7285b72e29cd2b8d8"
        }
    },
    "bin": [
        ["claude.exe", "claude"],
        ["claude.exe", "cc"]
    ],
    "pre_install": [
        "# 将 ~/.claude 软链接到 persist/data，升级时数据不丢失",
        "$claude_dir = Join-Path $env:USERPROFILE \".claude\"",
        "$persist_data = Join-Path $persist_dir \"data\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\link.ps1\" $claude_dir $persist_data"
    ],
    "post_uninstall": [
        "## 卸载时清理符号链接（数据保留在 persist 中）",
        "$claude_dir = Join-Path $env:USERPROFILE \".claude\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\unlink.ps1\" $claude_dir"
    ],
    "persist": ["data"],
    "checkver": {
        "url": "https://downloads.claude.ai/claude-code-releases/latest",
        "regex": "^([\\d.]+)$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.claude.ai/claude-code-releases/$version/win32-x64/claude.exe#/claude.exe",
                "hash": {
                    "url": "$baseurl/$version/manifest.json",
                    "jsonpath": "$.platforms['win32-x64'].checksum"
                }
            },
            "arm64": {
                "url": "https://downloads.claude.ai/claude-code-releases/$version/win32-arm64/claude.exe#/claude.exe",
                "hash": {
                    "url": "$baseurl/$version/manifest.json",
                    "jsonpath": "$.platforms['win32-arm64'].checksum"
                }
            }
        }
    }
}
