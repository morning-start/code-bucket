{
    "version": "0.17.0",
    "description": "GPU-accelerated terminal emulator",
    "homepage": "https://github.com/alacritty/alacritty",
    "license": "Apache-2.0",
    "notes": [
        "Already add Open with Alacritty as a context menu option by running"
    ],
    "suggest": {
        "vcredist": "extras/vcredist2022"
    },
    "url": "https://github.com/alacritty/alacritty/releases/download/v0.17.0/Alacritty-v0.17.0-portable.exe#/alacritty.exe",
    "hash": "5ad70ddc5c2a2bfe84084a2c4c73558e9360914f035a902d7a69277be7249f1f",
    "pre_install": [
        "# 将 %APPDATA%\\alacritty 软链接到 persist/data，升级时配置不丢失",
        "$alacritty_config = Join-Path $env:APPDATA \"alacritty\"",
        "$persist_data = Join-Path $persist_dir \"data\"",
        "& \"$bucketsdir\\code\\scripts\\link.ps1\" $alacritty_config $persist_data",
        "",
        "# 将 %APPDATA%\\Zellij 软链接到 persist/zellij，升级时配置不丢失",
        "$zellij_config = Join-Path $env:APPDATA \"Zellij\"",
        "$persist_zellij = Join-Path $persist_dir \"zellij\"",
        "& \"$bucketsdir\\code\\scripts\\link.ps1\" $zellij_config $persist_zellij"
    ],
    "post_install": [
        "$alacrittyPath = \"$dir\\alacritty.exe\".Replace('\\', '\\\\')",
        "'install-context', 'uninstall-context' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\extras\\scripts\\$app\\$_.reg\") {",
        "        $content = Get-Content \"$bucketsdir\\extras\\scripts\\$app\\$_.reg\"",
        "        $content = $content.Replace('$alacrittyPath', $alacrittyPath)",
        "        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }",
        "        Set-Content \"$dir\\$_.reg\" $content -Encoding Ascii -Force",
        "    }",
        "}",
        "reg import \"$dir\\install-context.reg\""
    ],
    "persist":["data","zellij"],
    "bin": "alacritty.exe",
    "shortcuts": [
        [
            "alacritty.exe",
            "Alacritty",
            "--working-directory \"%USERPROFILE%\""
        ]
    ],
    "pre_uninstall": "if ($cmd -eq 'uninstall') { reg import \"$dir\\uninstall-context.reg\" *> $null }",
    "post_uninstall": [
        "$alacritty_config = Join-Path $env:APPDATA \"alacritty\"",
        "& \"$bucketsdir\\code\\scripts\\unlink.ps1\" $alacritty_config",
        "$zellij_config = Join-Path $env:APPDATA \"Zellij\"",
        "& \"$bucketsdir\\code\\scripts\\unlink.ps1\" $zellij_config"
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/alacritty/alacritty/releases/download/v$version/Alacritty-v$version-portable.exe#/alacritty.exe"
    }
}
