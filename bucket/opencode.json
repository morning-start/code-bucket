    "architecture": {
        "64bit": {
            "url": "https://github.com/anomalyco/opencode/releases/download/v1.18.2/opencode-windows-x64.zip",
            "hash": "aca23b18d03639c6bd576a2dd23cebfa6dab80d31358f17cfa03fd1f2a5c41fd"
        },
        "arm64": {
            "url": "https://github.com/anomalyco/opencode/releases/download/v1.18.2/opencode-windows-arm64.zip",
            "hash": "7eb407240101a0ebca9acb99ed819a09a4211fdafa381161af6ca49f85736e4b"
        }
    },
    "bin": "opencode.exe",
    "pre_install": [
        "# 将 ~/.config/opencode 软链接到 persist/config，升级时数据不丢失",
        "$opencode_dir = Join-Path $env:USERPROFILE \".config\\opencode\"",
        "$persist_config = Join-Path $persist_dir \"config\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\link.ps1\" $opencode_dir $persist_config"
    ],
    "post_uninstall": [
        "$opencode_dir = Join-Path $env:USERPROFILE \".config\\opencode\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\unlink.ps1\" $opencode_dir"
    ],
    "persist": "config",
    "checkver": {
        "github": "https://github.com/anomalyco/opencode"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/anomalyco/opencode/releases/download/v$version/opencode-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/anomalyco/opencode/releases/download/v$version/opencode-windows-arm64.zip"
            }
        }
    }
}
