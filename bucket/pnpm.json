{
    "version": "11.5.2",
    "description": "A fast and disk space efficient Node package manager.",
    "homepage": "https://pnpm.io/",
    "license": "MIT",
    "notes": [
        "查看配置信息: pnpm config list",
        "",
        "切换国内源，推荐使用nrm进行管理"
    ],
    "depends": "bun",
    "suggest": {
        "Node.js": [
            "nodejs",
            "nodejs-lts",
            "nvm",
            "nvs"
        ]
    },
    "url": "https://raw.githubusercontent.com/morning-start/code-bucket/refs/heads/master/scripts/placeholder.txt",
    "pre_install": [
        "$pnpm_data_dirs = @(",
        "    @{ Source = 'pnpm\\store'; Name = 'store' },",
        "    @{ Source = 'pnpm\\bin'; Name = 'bin' },",
        "    @{ Source = 'pnpm\\state'; Name = 'state' },",
        "    @{ Source = 'pnpm\\global'; Name = 'global' },",
        "    @{ Source = 'pnpm-cache'; Name = 'pnpm-cache' }",
        ")",
        "foreach ($entry in $pnpm_data_dirs) {",
        "    $source = Join-Path $env:LOCALAPPDATA $entry.Source",
        "    $target = Join-Path $persist_dir $entry.Name",
        "    & \"$bucketsdir\\code\\scripts\\link.ps1\" $source $target",
        "}"
    ],
    "env_add_path": [
        "bin"
    ],
    "persist": [
        "bin",
        "store",
        "state",
        "global",
        "pnpm-cache"
    ]
}
