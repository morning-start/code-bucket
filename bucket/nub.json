{
    "version": "0.2.10",
    "description": "A fast all-in-one toolkit that augments Node.js instead of replacing it",
    "homepage": "https://nubjs.com/docs",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/nubjs/nub/releases/download/v0.2.10/nub-win32-x64.zip#/nub.zip",
            "hash": "sha256:9de0568a8f0292fb7e15a10e193c1995e8c46d59c481aaa3ab76a069f54d8fa3"
        }
    },
    "bin": [
       "bin/nub.exe",
       "bin/nubx.exe"
    ],
    "checkver": {
        "github": "https://github.com/nubjs/nub"
    },
    "env_add_path":["shims"],
    "pre_install": [
        "# 将 ~/.cache/nub 软链接到 persist/cache，升级时数据不丢失",
        "$nub_cache = Join-Path $env:USERPROFILE \".cache\\nub\"",
        "$persist_cache = Join-Path $persist_dir \"cache\"",
        "& \"$bucketsdir\\code\\scripts\\link.ps1\" $nub_cache $persist_cache",
        "# 将 ~/.nub/shims 软链接到 persist/shims，升级时数据不丢失",
        "$nub_shims = Join-Path $env:USERPROFILE \".nub\\shims\"",
        "$persist_shims = Join-Path $persist_dir \"shims\"",
        "& \"$bucketsdir\\code\\scripts\\link.ps1\" $nub_shims $persist_shims"
    ],
    "post_uninstall": [
        "## 卸载时清理链接",
        "$nub_cache = Join-Path $env:USERPROFILE \".cache\\nub\"",
        "& \"$bucketsdir\\code\\scripts\\unlink.ps1\" $nub_cache",
        "$nub_shims = Join-Path $env:USERPROFILE \".nub\\shims\"",
        "& \"$bucketsdir\\code\\scripts\\unlink.ps1\" $nub_shims"
    ],
    "persist": ["cache","shims"],
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nubjs/nub/releases/download/v$version/nub-win32-x64.zip#/nub.zip"
            }
        },
        "hash": {
            "url": "$baseurl.sha256"
        }
    }
}
